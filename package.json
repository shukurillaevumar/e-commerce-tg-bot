{
  "name": "telegram-stars-store-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Production-grade Telegram bot store for digital goods with Telegram Stars, Cloudflare Workers, D1 and KV.",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 migrations apply BOT_DB --local",
    "db:migrate:staging": "wrangler d1 migrations apply BOT_DB --env staging",
    "db:migrate:production": "wrangler d1 migrations apply BOT_DB --env production",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "grammy": "^1.38.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250906.0",
    "@types/node": "^24.3.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "wrangler": "^4.20.0"
  }
}
